# .env.example
# Copy this file to .env and fill in your values.
# .env is ignored by git so your keys remain safe.

# The script checks GROQ_API_KEY first, and if missing, falls back to HF_TOKEN.
# You can place your Groq API key in HF_TOKEN if you prefer.
HF_TOKEN=your_hf_or_groq_token_here
GROQ_API_KEY=

# Model configuration
MODEL_NAME=llama-3.3-70b-versatile
API_BASE_URL=https://api.groq.com/openai/v1


